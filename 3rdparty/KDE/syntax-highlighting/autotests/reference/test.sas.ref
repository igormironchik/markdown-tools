<Comment>/* ---- 4. FORMATS AND INFORMATS -------------------------------------- */</Comment><br/>
<Normal Text></Normal Text><br/>
<Step>data</Step><Normal Text> </Normal Text><Constants>_null_</Constants><Normal Text>;</Normal Text><br/>
<Normal Text>  </Normal Text><Keywords>format</Keywords><Normal Text> date_var  </Normal Text><Format>date9.</Format><Normal Text>;</Normal Text><br/>
