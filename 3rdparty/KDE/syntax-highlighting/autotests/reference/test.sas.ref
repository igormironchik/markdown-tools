<Normal Text>  </Normal Text><SecKeyword>define</SecKeyword><Normal Text> height </Normal Text><Operator>/</Operator><Normal Text> analysis mean format</Normal Text><Operator>=</Operator><Number>6.2</Number><Normal Text> </Normal Text><String>"Avg Height"</String><Normal Text>;</Normal Text><br/>
<Normal Text>  </Normal Text><SecKeyword>break</SecKeyword><Normal Text> after sex </Normal Text><Operator>/</Operator><Normal Text> summarize;</Normal Text><br/>
<Normal Text>  </Normal Text><SecKeyword>compute</SecKeyword><Normal Text> after sex;</Normal Text><br/>
<Normal Text>    </Normal Text><SecKeyword>line</SecKeyword><Normal Text> </Normal Text><String>"--- end of group ---"</String><Normal Text>;</Normal Text><br/>
