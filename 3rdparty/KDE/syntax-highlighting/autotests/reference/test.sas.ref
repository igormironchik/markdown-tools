<Comment>/* ---- 7. CONTROL FLOW ----------------------------------------------- */</Comment><br/>
<Normal Text></Normal Text><br/>
<Step>data</Step><Normal Text> </Normal Text><Constants>_null_</Constants><Normal Text>;</Normal Text><br/>
<Normal Text>  </Normal Text><Control>do</Control><Normal Text> i </Normal Text><Operator>=</Operator><Normal Text> </Normal Text><Number>1</Number><Normal Text> </Normal Text><Control>to</Control><Normal Text> </Normal Text><Number>10</Number><Normal Text> </Normal Text><Control>by</Control><Normal Text> </Normal Text><Number>2</Number><Normal Text>;</Normal Text><br/>
<Normal Text>    </Normal Text><Control>if</Control><Normal Text> i </Normal Text><Operator>=</Operator><Normal Text> </Normal Text><Number>5</Number><Normal Text> </Normal Text><Control>then</Control><Normal Text> </Normal Text><Keywords>continue</Keywords><Normal Text>;</Normal Text><br/>
<Normal Text>    </Normal Text><Control>if</Control><Normal Text> i </Normal Text><Operator>=</Operator><Normal Text> </Normal Text><Number>9</Number><Normal Text> </Normal Text><Control>then</Control><Normal Text> </Normal Text><Keywords>leave</Keywords><Normal Text>;</Normal Text><br/>
<Normal Text>    </Normal Text><Keywords>put</Keywords><Normal Text> i;</Normal Text><br/>
<Normal Text>  </Normal Text><Control>end</Control><Normal Text>;</Normal Text><br/>
<Normal Text></Normal Text><br/>
<Normal Text>  i </Normal Text><Operator>=</Operator><Normal Text> </Normal Text><Number>0</Number><Normal Text>;</Normal Text><br/>
<Normal Text>  </Normal Text><Control>do</Control><Normal Text> </Normal Text><Control>while</Control><Normal Text> (i </Normal Text><Operator><</Operator><Normal Text> </Normal Text><Number>10</Number><Normal Text>);</Normal Text><br/>
<Normal Text>    i </Normal Text><Operator>+</Operator><Normal Text> </Normal Text><Number>1</Number><Normal Text>;</Normal Text><br/>
<Normal Text>  </Normal Text><Control>end</Control><Normal Text>;</Normal Text><br/>
<Normal Text></Normal Text><br/>
<Normal Text>  i </Normal Text><Operator>=</Operator><Normal Text> </Normal Text><Number>0</Number><Normal Text>;</Normal Text><br/>
<Normal Text>  </Normal Text><Control>do</Control><Normal Text> </Normal Text><Control>until</Control><Normal Text> (i </Normal Text><Operator>>=</Operator><Normal Text> </Normal Text><Number>10</Number><Normal Text>);</Normal Text><br/>
<Normal Text>    i </Normal Text><Operator>+</Operator><Normal Text> </Normal Text><Number>1</Number><Normal Text>;</Normal Text><br/>
<Normal Text>  </Normal Text><Control>end</Control><Normal Text>;</Normal Text><br/>
<Normal Text></Normal Text><br/>
<Normal Text>  </Normal Text><Control>select</Control><Normal Text> (i);</Normal Text><br/>
<Normal Text>    </Normal Text><Control>when</Control><Normal Text> (</Normal Text><Number>1</Number><Normal Text>)  </Normal Text><Keywords>put</Keywords><Normal Text> </Normal Text><String>"one"</String><Normal Text>;</Normal Text><br/>
<Normal Text>    </Normal Text><Control>when</Control><Normal Text> (</Normal Text><Number>2</Number><Normal Text>)  </Normal Text><Keywords>put</Keywords><Normal Text> </Normal Text><String>"two"</String><Normal Text>;</Normal Text><br/>
<Normal Text>    </Normal Text><Control>otherwise</Control><Normal Text> </Normal Text><Keywords>put</Keywords><Normal Text> </Normal Text><String>"other"</String><Normal Text>;</Normal Text><br/>
<Normal Text>  </Normal Text><Control>end</Control><Normal Text>;</Normal Text><br/>
<Normal Text></Normal Text><br/>
<Normal Text>  </Normal Text><Control>if</Control><Normal Text> i </Normal Text><Operator>></Operator><Normal Text> </Normal Text><Number>5</Number><Normal Text> </Normal Text><Control>then</Control><Normal Text> </Normal Text><Keywords>put</Keywords><Normal Text> </Normal Text><String>"big"</String><Normal Text>;</Normal Text><br/>
<Normal Text>  </Normal Text><Control>else</Control><Normal Text> </Normal Text><Keywords>put</Keywords><Normal Text> </Normal Text><String>"small"</String><Normal Text>;</Normal Text><br/>
<Normal Text></Normal Text><br/>
<Normal Text>  </Normal Text><Control>goto</Control><Normal Text> done;</Normal Text><br/>
